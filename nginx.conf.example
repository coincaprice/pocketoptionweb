server {
    listen 80;
    server_name pocketoption.dev www.pocketoption.dev;

    if ($host = www.pocketoption.dev) {
        return 301 https://pocketoption.dev$request_uri;
    }

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name pocketoption.dev;

    ssl_certificate     /etc/letsencrypt/live/pocketoption.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/pocketoption.dev/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;

    # -------------------------------------------------------
    # Next.js static assets (JS, CSS, fonts, chunks)
    # Path: .next/standalone/.next/static/ (copied by deploy.sh)
    # -------------------------------------------------------
    location /_next/static/ {
        alias /var/www/pocketoption/artifacts/pocket-option-clone/.next/standalone/.next/static/;
        expires 1y;
        access_log off;
        add_header Cache-Control "public, immutable";
    }

    # -------------------------------------------------------
    # Public static files (favicon, sitemap, robots, images)
    # Path: .next/standalone/public/ (copied by deploy.sh)
    # -------------------------------------------------------
    location /images/ {
        alias /var/www/pocketoption/artifacts/pocket-option-clone/.next/standalone/public/images/;
        expires 30d;
        access_log off;
        add_header Cache-Control "public, max-age=2592000";
    }

    location /sitemap.xml {
        alias /var/www/pocketoption/artifacts/pocket-option-clone/.next/standalone/public/sitemap.xml;
        expires 1d;
        add_header Content-Type "application/xml";
    }

    location /sitemap.xsl {
        alias /var/www/pocketoption/artifacts/pocket-option-clone/.next/standalone/public/sitemap.xsl;
        expires 7d;
    }

    location /robots.txt {
        alias /var/www/pocketoption/artifacts/pocket-option-clone/.next/standalone/public/robots.txt;
        expires 1d;
        add_header Content-Type "text/plain";
    }

    location /site.webmanifest {
        alias /var/www/pocketoption/artifacts/pocket-option-clone/.next/standalone/public/site.webmanifest;
        expires 7d;
        add_header Content-Type "application/manifest+json";
    }

    location ~* \.(ico|png|webp|jpg|jpeg|svg|woff|woff2)$ {
        root /var/www/pocketoption/artifacts/pocket-option-clone/.next/standalone/public;
        expires 30d;
        access_log off;
        add_header Cache-Control "public, max-age=2592000";
    }

    # -------------------------------------------------------
    # All other requests proxied to Next.js standalone server
    # -------------------------------------------------------
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
